# Claw-Empire Environment Configuration
# Copy to .env and fill in your values

# Company Settings
COMPANY_NAME="My AI Company"
CEO_NAME="Your Name"

# AI Provider API Keys (add the ones you use)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
OPENAI_API_KEY=sk-YOUR_KEY_HERE
GOOGLE_AI_API_KEY=YOUR_KEY_HERE

# OAuth (optional - for GitHub/Google integration)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Messenger Integration (optional)
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_WEBHOOK_URL=

# OpenClaw Integration (optional)
INBOX_WEBHOOK_SECRET=
OPENCLAW_CONFIG=

# Server
PORT=3000
NODE_ENV=production

# Database (auto-configured, SQLite local-first)
DATABASE_URL=sqlite:./data/claw-empire.db
